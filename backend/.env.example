# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here
# Optional — model to use for all AI writing features. Check
# https://docs.claude.com for the current list of available model names.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional — port the backend listens on
PORT=3001

# Optional — the frontend dev server's origin, for CORS
FRONTEND_ORIGIN=http://localhost:5173
